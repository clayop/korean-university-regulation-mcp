{
  "name": "korean-university-regulation-mcp",
  "version": "0.2.1",
  "description": "MCP server for searching and querying Korean university regulations (한국 대학교 규정) - supports 14 universities",
  "type": "module",
  "bin": {
    "korean-university-regulation-mcp": "build/index.js"
  },
  "files": [
    "build",
    "data"
  ],
  "scripts": {
    "build": "tsc",
    "build-index": "tsx scripts/build-index.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "korean",
    "university",
    "regulation",
    "대학교",
    "규정",
    "kaist",
    "korea",
    "hansung",
    "khu"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cheerio": "^1.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
